<!DOCTYPE html><html lang="en"><head><%- include('partials/head') %></head><body>
<%- include('partials/header') %>

<div class="page-hero">
  <div class="page-hero-panel">
    <h1>GET IN <span style="color:var(--accent)">TOUCH</span></h1>
    <p>Questions, orders, wholesale enquiries. We answer fast.</p>
  </div>
</div>

<section class="page-shell">
  <div class="container">
    <% var callPhones = site.phones.filter(function (ph) { return ph.type !== 'whatsapp'; }); %>
    <% var waPhones = site.phones.filter(function (ph) { return ph.type === 'whatsapp'; }); %>
    <div class="contact-grid">
      <div class="contact-cards">
        <% if (callPhones.length) { %>
        <div class="contact-card reveal">
          <span class="cc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h4l2 5-2.5 1.5a12 12 0 0 0 5 5L15 13l5 2v4a2 2 0 0 1-2 2A16 16 0 0 1 3 6a2 2 0 0 1 2-2z"/></svg></span>
          <div><h4>Call us</h4>
          <p><% callPhones.forEach(function (ph, i) { %><% if (i) { %><br><% } %><%= ph.label || 'Phone' %>: <a href="tel:<%= String(ph.number || '').replace(/[^0-9+]/g, '') %>"><%= ph.number %></a><% }); %></p></div>
        </div>
        <% } %>
        <% if (waPhones.length) { %>
        <div class="contact-card reveal">
          <span class="cc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3a9 9 0 0 0-7.8 13.4L3 21l4.8-1.2A9 9 0 1 0 12 3z"/><path d="M9 8.5c.5 2.5 3 5 5.5 5.5l1-1.5 2 1c-.5 1.5-1.5 2-3 2-3.5-.5-6.5-3.5-7-7 0-1.5.5-2.5 2-3l1 2z" fill="currentColor" stroke="none"/></svg></span>
          <div><h4>WhatsApp</h4>
          <p>Fastest way to order or ask anything.<% waPhones.forEach(function (ph) { %><% var wa = String(ph.number || '').replace(/[^0-9]/g, ''); if (wa.charAt(0) === '0') { wa = '94' + wa.slice(1); } %><br>
          <a href="https://wa.me/<%= wa %>?text=Hi%20Car%20Spa%20LK!">Chat with us on WhatsApp</a><% }); %></p></div>
        </div>
        <% } %>
        <div class="contact-card reveal">
          <span class="cc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2.5"/><path d="m4 7 8 6 8-6"/></svg></span>
          <div><h4>Email</h4>
          <p><a href="mailto:<%= site.settings.email %>"><%= site.settings.email %></a><br>
          We reply within one working day.</p></div>
        </div>
        <div class="contact-card reveal">
          <span class="cc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s7-6.1 7-11a7 7 0 1 0-14 0c0 4.9 7 11 7 11z"/><circle cx="12" cy="10" r="2.6"/></svg></span>
          <div><h4>Visit us</h4>
          <p><% String(site.settings.address || '').split(/\r?\n/).forEach(function (line, i) { %><% if (i) { %><br><% } %><%= line %><% }); %></p></div>
        </div>
        <div class="contact-card reveal">
          <span class="cc-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8.5"/><path d="M12 7v5l3.5 2"/></svg></span>
          <div><h4>Opening hours</h4>
          <% var dayNames = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']; %>
          <% var hoursByDay = {}; site.hours.forEach(function (h) { hoursByDay[h.day_of_week] = h; }); %>
          <p><% for (var d = 0; d < 7; d++) { var h = hoursByDay[d]; %><% if (d) { %><br><% } %><%= dayNames[d] %>: <% if (!h || h.is_closed || !h.open_time || !h.close_time) { %>Closed<% } else { %><%= String(h.open_time).slice(0, 5) %> – <%= String(h.close_time).slice(0, 5) %><% } %><% } %><% site.hourNotes.forEach(function (n) { %><br><%= n.note %><% }); %></p></div>
        </div>
      </div>
      <div class="co-panel reveal reveal-right">
        <h3>Send us a message</h3>
        <form id="contact-form" data-email="<%= site.settings.email %>">
          <div class="form-row">
            <div class="form-field">
              <label for="cf-name">Your name</label>
              <input id="cf-name" name="name" type="text" required autocomplete="name">
            </div>
            <div class="form-field">
              <label for="cf-phone">Phone (optional)</label>
              <input id="cf-phone" name="phone" type="tel" autocomplete="tel">
            </div>
          </div>
          <div class="form-field">
            <label for="cf-subject">Subject</label>
            <select id="cf-subject" name="subject" required>
              <option>Order enquiry</option>
              <option>Product question</option>
              <option>Become a dealer / stockist</option>
              <option>Something else</option>
            </select>
          </div>
          <div class="form-field">
            <label for="cf-message">Message</label>
            <textarea id="cf-message" name="message" rows="6" required></textarea>
          </div>
          <button class="btn btn-accent" type="submit">Send message <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></button>
          <p class="form-note" hidden>Your email app should open with the message ready to send to <%= site.settings.email %>. If it didn't, just email us directly.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
