<!DOCTYPE html><html lang="en"><head><%- include('partials/head') %></head><body>
<%- include('partials/header') %>

<section class="page-shell" id="cart-page">
  <div class="container">
    <h1>Your <strong class="hl">cart</strong></h1>
    <p class="page-lead">Review your items, then check out. We confirm every order with you before anything is charged.</p>
    <noscript><p style="margin-top:20px;">The cart needs JavaScript to work. Please enable it, or order directly on 074 2 388 588.</p></noscript>
    <div class="cart-items"></div>
    <div class="cart-empty" hidden>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 4h3l2.5 12.5A2 2 0 0 0 10.5 18h8a2 2 0 0 0 2-1.6L22 8H7"/><circle cx="10" cy="21" r="1.6"/><circle cx="18" cy="21" r="1.6"/></svg>
      <h2>Your cart is empty</h2>
      <p>Let's fix that. The good stuff is one click away.</p>
      <a class="btn btn-accent" href="/products">Browse products <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
    </div>
    <div class="cart-summary" hidden>
      <span class="cart-total">Total<b class="cart-total-value">Rs. 0</b></span>
      <a class="btn btn-outline" href="/products">Continue shopping</a>
      <a class="btn btn-accent" href="/checkout">Checkout <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
