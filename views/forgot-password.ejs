<!DOCTYPE html><html lang="en"><head><%- include('partials/head') %></head><body>
<%- include('partials/header') %>

<div class="page-hero">
  <div class="page-hero-panel">
    <h1>FORGOT <span style="color:var(--accent)">PASSWORD</span></h1>
    <p>We will email you a link to set a new one.</p>
  </div>
</div>

<style>
  .fp-wrap { max-width: 460px; margin: 0 auto; }
  .fp-wrap .form-error { margin-top: 4px; margin-bottom: 16px; font-size: 14px; color: var(--accent-dark); font-weight: 700; }
</style>

<section class="page-shell">
  <div class="container">
    <div class="fp-wrap">
      <div class="co-panel reveal">
        <h3>Reset your password</h3>
        <% if (sent) { %>
        <p class="form-note">If that email is on file, a reset link is on its way. Check your inbox in a few minutes.</p>
        <% } else { %>
        <form method="post" action="/forgot-password">
          <div class="form-field">
            <label for="fp-email">Admin email</label>
            <input id="fp-email" name="email" type="email" required autocomplete="email">
          </div>
          <button class="btn btn-accent" type="submit">Send reset link <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></button>
        </form>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
