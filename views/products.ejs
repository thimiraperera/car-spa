<!DOCTYPE html><html lang="en"><head><%- include('partials/head') %></head><body>
<% var BLANK_IMG = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7'; %>
<%
  var CAT_PILLS = [
    { key: 'all', label: 'All' },
    { key: 'engine', label: 'Engine Care' },
    { key: 'exterior', label: 'Exterior &amp; Shine' },
    { key: 'interior', label: 'Interior &amp; AC' },
    { key: 'brake', label: 'Brake &amp; Underbody' },
    { key: 'chain', label: 'Bike &amp; Chain' }
  ];
  var catHref = function (key) { return key === 'all' ? '/products' : '/products?cat=' + key; };
  var pageHref = function (n) {
    var params = [];
    if (currentCat !== 'all') params.push('cat=' + currentCat);
    params.push('page=' + n);
    return '/products?' + params.join('&');
  };
%>

<%- include('partials/header') %>

<div class="page-hero">
  <div class="page-hero-panel">
    <h1>ALL <span style="color:var(--accent)">PRODUCTS</span></h1>
    <p>Professional-grade auto care, delivered island-wide.</p>
  </div>
</div>

<section style="padding-top:30px;">
  <div class="container">
    <div class="filter-row" id="filters">
      <% CAT_PILLS.forEach(function (pill) { %>
      <a class="filter-pill<%= currentCat === pill.key ? ' active' : '' %>" href="<%= catHref(pill.key) %>"><%- pill.label %></a>
      <% }); %>
    </div>
    <div class="prod-grid three" id="catalog" style="margin-top:34px;">
      <% products.forEach(function (p, i) { %>
      <a class="prod-card reveal" data-cat="<%= p.cat_key %>" href="<%= p.url %>" style="--rd:<%= ((i % 4) * 0.07).toFixed(2) %>s">
        <div class="prod-media">
          <% if (p.category) { %><span class="badge-cat"><%= p.category %></span><% } %>
          <img src="<%= p.image || BLANK_IMG %>" alt="<%= p.name %>"<% if (i === 0) { %> fetchpriority="high"<% } else if (i >= 3) { %> loading="lazy"<% } %> decoding="async" onerror="this.remove()">
        </div>
        <div class="prod-body">
          <h4><%= p.name %></h4>
          <div class="prod-rating" aria-hidden="true">★★★★★</div>
          <span class="prod-size"><%= p.size %></span>
          <div class="prod-foot">
            <span class="prod-price">Rs. <%= Number(p.price_lkr).toLocaleString('en-US') %></span>
            <span class="prod-view" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
    <% if (totalPages > 1) { %>
    <nav class="pg-nav" aria-label="Products pagination">
      <% if (currentPage > 1) { %><a class="pg-btn" href="<%= pageHref(currentPage - 1) %>">Prev</a><% } else { %><span class="pg-btn disabled">Prev</span><% } %>
      <% for (var n = 1; n <= totalPages; n++) { %>
        <% if (n === currentPage) { %><span class="pg-num active"><%= n %></span><% } else { %><a class="pg-num" href="<%= pageHref(n) %>"><%= n %></a><% } %>
      <% } %>
      <% if (currentPage < totalPages) { %><a class="pg-btn" href="<%= pageHref(currentPage + 1) %>">Next</a><% } else { %><span class="pg-btn disabled">Next</span><% } %>
    </nav>
    <% } %>
  </div>
</section>

<section style="padding-top:0;">
  <div class="container">
    <div class="cta-band">
      <h2>Buying for a workshop or fleet?<br>Ask us about wholesale pricing!</h2>
      <a class="btn btn-accent" href="/contact">Talk to Car Spa LK <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
