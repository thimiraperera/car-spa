<!DOCTYPE html><html lang="en"><head><%- include('partials/head') %></head><body>
<% var BLANK_IMG = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7'; %>
<% var initials = function (name) { var parts = String(name || '').trim().split(/\s+/); var out = ''; for (var i = 0; i < parts.length && out.length < 2; i++) { if (parts[i]) out += parts[i].charAt(0); } return out.toUpperCase(); }; %>

<%- include('partials/header') %>

<!-- ===== Hero ===== -->
<div class="hero">
  <div class="hero-panel">
    <div class="hero-bg" aria-hidden="true" data-parallax="-0.1">
      <img class="hero-bg-img" src="/assets/img/site/hero-home.webp" alt="" onerror="this.remove()">
      <img class="hero-bg-img" src="/assets/img/site/hero-home-2.webp" alt="" onerror="this.remove()">
      <img class="hero-bg-img" src="/assets/img/site/hero-home-3.webp" alt="" onerror="this.remove()">
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-top">
      <h1 class="hero-wordmark">CARSPA<span class="lk">.LK</span></h1>
      <p class="hero-sub">Auto care, done right</p>
    </div>
    <div class="hero-relight" id="hero-relight" aria-hidden="true" data-parallax="0.05">
      <img data-light="left" src="/assets/img/site/hero-relight-left.webp" alt="" onerror="this.remove()">
      <img data-light="center" src="/assets/img/site/hero-relight-center.webp" alt="" onerror="this.remove()">
      <img data-light="right" src="/assets/img/site/hero-relight-right.webp" alt="" onerror="this.remove()">
      <img data-light="off" src="/assets/img/site/hero-relight-lightsoff.webp" alt="" onerror="this.remove()">
      <img data-light="on" src="/assets/img/site/hero-relight-lightson.webp" alt="" onerror="this.remove()">
    </div>
    <div class="hero-spotlight" id="hero-spotlight" aria-hidden="true"></div>
    <div class="hero-dust" aria-hidden="true">
      <span></span><span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span><span></span><span></span>
      <span></span><span></span><span></span><span></span>
    </div>
    <div class="hero-bottom">
      <a class="btn btn-cream" href="/products">Discover our products <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
      <div class="hero-picks" id="hero-picks" aria-label="Popular picks">
        <span class="hero-picks-label">Popular now</span>
        <div class="hero-picks-row" data-vehicle="car">
          <% picksCar.forEach(function (p) { %>
          <a class="hero-pick" href="/products/<%= p.slug %>">
            <img src="<%= p.image || BLANK_IMG %>" alt="" loading="lazy" decoding="async" onerror="this.remove()">
            <span><%= p.name %><small>Rs. <%= Number(p.price_lkr).toLocaleString('en-US') %></small></span>
          </a>
          <% }); %>
        </div>
        <div class="hero-picks-row" data-vehicle="bike" hidden>
          <% picksBike.forEach(function (p) { %>
          <a class="hero-pick" href="/products/<%= p.slug %>">
            <img src="<%= p.image || BLANK_IMG %>" alt="" loading="lazy" decoding="async" onerror="this.remove()">
            <span><%= p.name %><small>Rs. <%= Number(p.price_lkr).toLocaleString('en-US') %></small></span>
          </a>
          <% }); %>
        </div>
      </div>
      <div class="hero-toggle" id="vehicle-toggle" title="Shop by vehicle">
        <span class="tog-thumb" aria-hidden="true"></span>
        <button class="tog active" data-vehicle="car" aria-label="Show car products">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3.5 15.5h1a2.4 2.4 0 0 0 4.6 0h5.8a2.4 2.4 0 0 0 4.6 0h1a1 1 0 0 0 1-1v-1.6c0-.9-.6-1.6-1.5-1.8l-3.1-.7-2.2-2.8a2 2 0 0 0-1.6-.8H8.6a2 2 0 0 0-1.8 1.1l-1.3 2.6-2 .5a1.6 1.6 0 0 0-1.2 1.6v1.9a1 1 0 0 0 1.2 1z"/><circle cx="6.8" cy="15.7" r="1.7"/><circle cx="16.2" cy="15.7" r="1.7"/><path d="M9.2 7.9 8.3 10h7.2l-1.6-2.1z" fill="currentColor" stroke="none" opacity=".35"/></svg>
          <span>Car</span>
        </button>
        <button class="tog" data-vehicle="bike" aria-label="Show bike products">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="5.6" cy="16.4" r="3.1"/><circle cx="18.4" cy="16.4" r="3.1"/><path d="M5.6 16.4h4.2l2.6-4.6h3.2"/><path d="M18.4 16.4 15.4 8.6h-2.2"/><path d="M14.6 6.8h2.6l.7 1.8"/><path d="M8.2 11.8h4"/></svg>
          <span>Bike</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ===== Categories ===== -->
<section>
  <div class="container center">
    <h2 class="section-title">All our products <strong class="hl">in one place!</strong></h2>
    <p class="section-lead">Professional-grade auto care for every part of your vehicle, from the engine bay to the last detail of your interior.</p>
    <div class="cat-grid">
      <a class="cat-card reveal" href="/products#engine">
        <div class="cat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="7" y="5" width="10" height="3" rx="0.5"/><rect x="5" y="8" width="14" height="9" rx="1"/><line x1="9" y1="8" x2="9" y2="17"/><line x1="12" y1="8" x2="12" y2="17"/><line x1="15" y1="8" x2="15" y2="17"/><circle cx="9" cy="5" r="0.4"/><circle cx="15" cy="5" r="0.4"/><path d="M19 12 L21 12 L21 17"/><line x1="5" y1="19.5" x2="19" y2="19.5"/><line x1="5" y1="18.8" x2="5" y2="20.2"/><line x1="19" y1="18.8" x2="19" y2="20.2"/></svg></div>
        <h4>Engine Care</h4><p>Flushes &amp; cleaners</p>
      </a>
      <a class="cat-card reveal" href="/products#exterior">
        <div class="cat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17 L3 14 L5 14 L7 10 L14 9 L17 12 L21 12 L21 17 Z"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="0.6"/><circle cx="17" cy="18" r="0.6"/><line x1="16.5" y1="4" x2="18.5" y2="6"/><line x1="18.5" y1="4" x2="16.5" y2="6"/><line x1="2" y1="21" x2="22" y2="21"/><line x1="2" y1="20.3" x2="2" y2="21.7"/><line x1="22" y1="20.3" x2="22" y2="21.7"/></svg></div>
        <h4>Exterior &amp; Shine</h4><p>Polish &amp; restore</p>
      </a>
      <a class="cat-card reveal" href="/products#interior">
        <div class="cat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="4" width="6" height="3" rx="1"/><line x1="10" y1="7" x2="10" y2="8"/><line x1="14" y1="7" x2="14" y2="8"/><rect x="6" y="8" width="12" height="9" rx="1.5"/><line x1="12" y1="8" x2="12" y2="17"/><line x1="19" y1="3" x2="19" y2="6"/><line x1="17.7" y1="3.25" x2="20.3" y2="5.75"/><line x1="20.3" y1="3.25" x2="17.7" y2="5.75"/><line x1="6" y1="19.5" x2="18" y2="19.5"/><line x1="6" y1="18.8" x2="6" y2="20.2"/><line x1="18" y1="18.8" x2="18" y2="20.2"/></svg></div>
        <h4>Interior &amp; AC</h4><p>Fresh &amp; germ-free</p>
      </a>
      <a class="cat-card reveal" href="/products#brake">
        <div class="cat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="7"/><circle cx="12" cy="12" r="2"/><line x1="12" y1="6" x2="12" y2="4.7"/><line x1="16.24" y1="7.76" x2="17.16" y2="6.84"/><line x1="18" y1="12" x2="19.3" y2="12"/><line x1="16.24" y1="16.24" x2="17.16" y2="17.16"/><line x1="12" y1="18" x2="12" y2="19.3"/><line x1="7.76" y1="16.24" x2="6.84" y2="17.16"/><line x1="6" y1="12" x2="4.7" y2="12"/><line x1="7.76" y1="7.76" x2="6.84" y2="6.84"/><rect x="9.5" y="2.5" width="5" height="4" rx="1"/><circle cx="10.7" cy="4.5" r="0.4"/><circle cx="13.3" cy="4.5" r="0.4"/><line x1="5" y1="21" x2="19" y2="21"/><line x1="5" y1="20.3" x2="5" y2="21.7"/><line x1="19" y1="20.3" x2="19" y2="21.7"/></svg></div>
        <h4>Brake &amp; Underbody</h4><p>Clean &amp; protect</p>
      </a>
      <a class="cat-card reveal" href="/products#chain">
        <div class="cat-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="13" r="5"/><circle cx="9" cy="13" r="1.3"/><line x1="9" y1="8" x2="9" y2="6.7"/><line x1="12.54" y1="9.46" x2="13.45" y2="8.55"/><line x1="12.54" y1="16.54" x2="13.45" y2="17.45"/><line x1="9" y1="18" x2="9" y2="19.3"/><line x1="5.46" y1="16.54" x2="4.55" y2="17.45"/><line x1="4" y1="13" x2="2.7" y2="13"/><line x1="5.46" y1="9.46" x2="4.55" y2="8.55"/><path d="M19 11.5 Q21 14.5 19 17.5 Q17 14.5 19 11.5 Z"/><line x1="14" y1="13" x2="19" y2="11.5"/><line x1="3" y1="21" x2="21" y2="21"/><line x1="3" y1="20.3" x2="3" y2="21.7"/><line x1="21" y1="20.3" x2="21" y2="21.7"/></svg></div>
        <h4>Bike &amp; Chain Care</h4><p>Lube &amp; clean</p>
      </a>
    </div>
  </div>
</section>

<!-- ===== Story ===== -->
<section class="story">
  <div class="container">
    <div class="story-grid">
      <div class="story-media reveal reveal-left">
        <img src="/assets/img/site/story-workshop.webp" alt="Detailer hand-polishing a car panel" loading="lazy" decoding="async" data-parallax="-0.06" onerror="this.remove()">
      </div>
      <div class="story-copy reveal reveal-right">
        <p class="eyebrow">The Car Spa promise</p>
        <h2 class="section-title">Workshop grade. <strong class="hl">Driveway simple.</strong></h2>
        <p>Every bottle we stock is genuine Arkos Vetek, the same professional range used in workshops across Sri Lanka. Clear instructions, honest pricing, and results you can see the first time you use it.</p>
        <div class="story-stats">
          <div><b data-count="14">14</b><small>Products in range</small></div>
          <div><b data-count="180" data-suffix="+">180+</b><small>Verified reviews</small></div>
          <div><b data-count="4.9" data-decimals="1">4.9</b><small>Average rating</small></div>
        </div>
        <a class="btn btn-dark" href="/products">Browse the range <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
      </div>
    </div>
  </div>
</section>

<!-- ===== Product finder ===== -->
<section class="section-cream curve-top" style="padding-top:0;">
  <div class="container" style="padding-top:50px;">
    <div class="finder">
      <div>
        <h2>Find the <strong class="hl">right product</strong> for your vehicle!</h2>
        <p>Tell us what you're dealing with and we'll point you to the right bottle. No guesswork, no wasted money, just results you can see.</p>
        <div class="finder-media" id="finder-media">
          <img src="/assets/img/site/finder-mechanic.webp" class="active" data-key="default" alt="Inspecting a motorcycle chain with a flashlight" decoding="async" onerror="this.remove()">
          <img src="/assets/img/site/finder-engine.webp" data-key="engine" alt="" loading="lazy" decoding="async" onerror="this.remove()">
          <img src="/assets/img/site/finder-headlight.webp" data-key="headlight" alt="" loading="lazy" decoding="async" onerror="this.remove()">
          <img src="/assets/img/site/finder-ac.webp" data-key="ac" alt="" loading="lazy" decoding="async" onerror="this.remove()">
          <img src="/assets/img/site/finder-chain.webp" data-key="chain" alt="" loading="lazy" decoding="async" onerror="this.remove()">
          <img src="/assets/img/site/finder-rust.webp" data-key="rust" alt="" loading="lazy" decoding="async" onerror="this.remove()">
          <img src="/assets/img/site/finder-radiator.webp" data-key="radiator" alt="" loading="lazy" decoding="async" onerror="this.remove()">
        </div>
      </div>
      <div class="finder-options" id="finder-options">
        <a href="/products/engine-flush-4-wheeler" data-media="engine">My engine feels sluggish <span class="arr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
        <a href="/products/headlight-polish" data-media="headlight">My headlights are cloudy <span class="arr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
        <a href="/products/ac-disinfectant-spray" data-media="ac">My AC smells musty <span class="arr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
        <a href="/products/chain-lube" data-media="chain">My bike chain is noisy <span class="arr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
        <a href="/products/rust-off" data-media="rust">I can see rust forming <span class="arr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
        <a href="/products/radiator-flush" data-media="radiator">My engine runs hot <span class="arr"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
      </div>
    </div>
  </div>
</section>

<!-- ===== Featured products ===== -->
<section class="section-cream" style="padding-top:40px;">
  <div class="container">
    <div class="prod-head">
      <div>
        <h2 class="section-title">Made for <strong class="hl">performance</strong>, priced for every garage!</h2>
        <p class="section-lead">Our best-selling essentials, trusted by detailers and daily drivers across Sri Lanka.</p>
      </div>
      <a class="btn btn-dark" href="/products">All products <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
    </div>
    <div class="prod-carousel">
      <button class="carousel-btn prev" type="button" aria-label="Previous products"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></button>
      <div class="prod-carousel-viewport" id="featured-viewport">
      <div class="prod-grid" id="featured-grid">
      <% var rdCar = 0, rdBike = 0; %>
      <% carousel.forEach(function (p) { %>
      <% var rd = p.vehicle === 'bike' ? rdBike++ : rdCar++; %>
      <a class="prod-card reveal" data-vehicle="<%= p.vehicle %>"<% if (p.vehicle === 'bike') { %> hidden<% } %> href="/products/<%= p.slug %>" style="--rd:<%= (rd * 0.07).toFixed(2) %>s">
        <div class="prod-media">
          <% if (p.category) { %><span class="badge-cat"><%= p.category %></span><% } %>
          <img src="<%= p.image || BLANK_IMG %>" alt="<%= p.name %>" loading="lazy" decoding="async" onerror="this.remove()">
        </div>
        <div class="prod-body">
          <h4><%= p.name %></h4>
          <div class="prod-rating" aria-hidden="true">★★★★★</div>
          <span class="prod-size"><%= p.size %></span>
          <div class="prod-foot">
            <span class="prod-price">Rs. <%= Number(p.price_lkr).toLocaleString('en-US') %></span>
            <span class="prod-view" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span>
          </div>
        </div>
      </a>
      <% }); %>
      </div>
      </div>
      <button class="carousel-btn next" type="button" aria-label="Next products"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></button>
    </div>
  </div>
</section>

<!-- ===== Benefits ===== -->
<section id="why-us">
  <div class="container center">
    <h2 class="section-title">Why <strong class="hl">Car Spa LK?</strong> Because the results speak for themselves!</h2>
    <p class="section-lead">Every product in our range is formulated for professional workshops, and made simple enough for your driveway. Here's what you'll notice from the first use.</p>
    <div class="benefits-grid">
      <div class="benefit reveal">
        <div class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M13 2 4 14h6l-1 8 9-12h-6z"/></svg></div>
        <h4>Restored performance</h4>
        <p>Engines breathe easier and respond faster after a proper clean.</p>
      </div>
      <div class="benefit reveal">
        <div class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><circle cx="12" cy="12" r="9"/><path d="m8 12 3 3 5-6"/></svg></div>
        <h4>Showroom shine</h4>
        <p>Deep gloss and clarity that lasts, outside and in.</p>
      </div>
      <div class="benefit reveal">
        <div class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 3c3 3 7 4 7 9a7 7 0 0 1-14 0c0-5 4-6 7-9z"/></svg></div>
        <h4>Fresh, healthy cabin</h4>
        <p>Kill odour-causing bacteria at the source, not just mask it.</p>
      </div>
      <div class="benefit reveal">
        <div class="b-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 3 4 6v6c0 5 3.5 8 8 9 4.5-1 8-4 8-9V6z"/></svg></div>
        <h4>Long-term protection</h4>
        <p>Stop rust, wear and grime before they cost you real money.</p>
      </div>
    </div>
    <div style="margin-top:52px;">
      <a class="btn btn-accent" href="/products">Explore the full range <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
    </div>
  </div>
</section>

<!-- ===== Marquee ===== -->
<div class="marquee-band" aria-hidden="true">
  <div class="marquee-track">
    <span>CAR SPA LK</span><span>auto care done right!</span><span>CAR SPA LK</span><span>auto care done right!</span>
    <span>CAR SPA LK</span><span>auto care done right!</span><span>CAR SPA LK</span><span>auto care done right!</span>
    <span>CAR SPA LK</span><span>auto care done right!</span><span>CAR SPA LK</span><span>auto care done right!</span>
  </div>
</div>

<!-- ===== Reviews ===== -->
<section class="section-cream">
  <div class="container center">
    <p style="letter-spacing:.2em; font-weight:800; font-size:12px; color:var(--accent); text-transform:uppercase;">Customer Reviews</p>
    <h2 class="section-title">Cars that turned heads, <strong class="hl">owners who told everyone!</strong></h2>
    <div class="testi-carousel">
      <div class="testi-viewport">
        <div class="testi-track">
          <% for (var rep = 0; rep < 2; rep++) { %>
          <% testimonials.forEach(function (t) { %>
          <div class="testi-slide"<% if (rep > 0) { %> aria-hidden="true"<% } %>>
            <div class="review-card">
              <div class="review-top">
                <div class="avatar"><%= initials(t.customer_name) %></div>
                <div><h5><%= t.customer_name %></h5><small><%= t.detail %></small></div>
              </div>
              <div class="stars"><%= '★'.repeat(Math.max(1, Math.min(5, Number(t.rating) || 5))) %></div>
              <p><%= t.quote %></p>
            </div>
          </div>
          <% }); %>
          <% } %>
        </div>
      </div>
    </div>
    <div class="review-score">
      <span class="score" data-count="4.9" data-decimals="1">4.9</span>
      <small>Based on 180+ verified reviews<br>from customers island-wide</small>
    </div>
  </div>
</section>

<!-- ===== FAQ ===== -->
<section>
  <div class="container center">
    <h2 class="section-title">Got questions? <strong class="hl">We've got answers!</strong></h2>
    <p class="section-lead">Everything you need to know about our products, ordering and delivery. We're here to make it easy.</p>
    <div class="faq-wrap" style="text-align:left;">
      <% faqs.forEach(function (f, i) { %>
      <details class="faq-item reveal"<% if (i === 0) { %> open<% } %>>
        <summary><%= f.question %></summary>
        <div class="faq-body"><%- f.answer %></div>
      </details>
      <% }); %>
    </div>
  </div>
</section>

<!-- ===== CTA ===== -->
<section style="padding-top:0;">
  <div class="container">
    <div class="cta-band">
      <h2>Not sure what your ride needs?<br>Message us and we'll sort you out!</h2>
      <a class="btn btn-accent" href="/contact">Talk to Car Spa LK <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></a>
    </div>
  </div>
</section>

<script>
// Vehicle toggle: slide the thumb, filter featured products, swap hero quick picks
document.querySelectorAll('.hero-toggle .tog').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.hero-toggle .tog').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const v = btn.dataset.vehicle;
    document.getElementById('vehicle-toggle').classList.toggle('bike', v === 'bike');
    document.querySelectorAll('#featured-grid .prod-card').forEach(card => {
      card.hidden = card.dataset.vehicle !== v;
    });
    const viewport = document.getElementById('featured-viewport');
    if (viewport) viewport.scrollTo({ left: 0 });
    document.querySelectorAll('#hero-picks .hero-picks-row').forEach(row => {
      if (row.dataset.vehicle === v) {
        row.hidden = false;
        row.classList.remove('swap-in');
        void row.offsetWidth; /* restart the swap animation */
        row.classList.add('swap-in');
      } else {
        row.hidden = true;
      }
    });
  });
});
</script>
<%- include('partials/footer') %>
</body>
</html>
