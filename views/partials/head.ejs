<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= meta.title %></title>
<% if (meta.description) { %><meta name="description" content="<%= meta.description %>"><% } %>
<% if (meta.robots) { %><meta name="robots" content="<%= meta.robots %>"><% } %>
<link rel="canonical" href="<%= meta.canonical %>">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Car Spa LK">
<meta property="og:title" content="<%= meta.socialTitle %>">
<% if (meta.socialDescription) { %><meta property="og:description" content="<%= meta.socialDescription %>"><% } %>
<meta property="og:url" content="<%= meta.canonical %>">
<% if (meta.image) { %><meta property="og:image" content="<%= meta.image %>"><% } %>
<meta name="twitter:card" content="<%= meta.image ? 'summary_large_image' : 'summary' %>">
<meta name="twitter:title" content="<%= meta.xTitle %>">
<% if (meta.xDescription) { %><meta name="twitter:description" content="<%= meta.xDescription %>"><% } %>
<% if (meta.image) { %><meta name="twitter:image" content="<%= meta.image %>"><% } %>
<link rel="stylesheet" href="/styles.css?v=<%= v %>">
<noscript><style>.reveal{opacity:1!important;transform:none!important}</style></noscript>
<% (jsonld || []).forEach(function (schema) { %>
<script type="application/ld+json"><%- JSON.stringify(schema).replace(/</g, '\\u003c') %></script>
<% }); %>
