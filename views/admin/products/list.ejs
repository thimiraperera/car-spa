<%- include('../partials/top') %>
<% const pageLink = function (pn) { return '/admin/products?page=' + pn + (per !== 10 ? '&per=' + per : ''); }; %>
<style>
  .adm-pager { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 18px; }
  .adm-pager a, .adm-pager span {
    display: inline-block; min-width: 34px; text-align: center; padding: 7px 10px;
    border-radius: 8px; border: 1.5px solid var(--line); font-size: 13px; font-weight: 600;
    text-decoration: none; color: var(--ink);
  }
  .adm-pager a:hover { border-color: var(--ink); }
  .adm-pager a.on { background: var(--accent); border-color: var(--accent); color: #fff; }
  .adm-pager span.disabled { color: var(--ink-soft); opacity: .5; }
</style>
<header class="adm-head">
  <h1>Products</h1>
  <div class="adm-head-actions">
    <form class="adm-perpage" method="get">
      <label>Show
        <select name="per" onchange="this.form.submit()">
          <% [10, 25, 50, 100].forEach(function (n) { %>
          <option value="<%= n %>" <%= per === n ? 'selected' : '' %>><%= n %></option>
          <% }); %>
        </select>
      per page</label>
    </form>
    <a class="adm-btn" href="/admin/products/new">Add product</a>
  </div>
</header>

<section class="adm-panel">
  <table class="adm-table">
    <thead>
      <tr>
        <th></th>
        <th>Name</th>
        <th>Vehicle</th>
        <th>Category</th>
        <th class="num">Price</th>
        <th class="num">Stock</th>
        <th>Size</th>
        <th>Status</th>
        <th class="num">Clicks</th>
        <th class="actions">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(function (p) { %>
      <tr>
        <td>
          <% if (p.featured_image) { %>
          <img class="thumb" src="/media/<%= p.featured_image %>" alt="">
          <% } else { %>
          <span class="thumb"></span>
          <% } %>
        </td>
        <td><a href="/admin/products/<%= p.id %>/edit"><%= p.name %></a></td>
        <td class="muted"><%= p.vehicle.charAt(0).toUpperCase() + p.vehicle.slice(1) %></td>
        <td class="muted"><%= p.category || '' %></td>
        <td class="num">Rs <%= Number(p.price_lkr).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) %></td>
        <td class="num">
          <% if (p.stock_qty === null) { %>&#8734;<% } else if (p.stock_qty === 0) { %><span class="adm-pill off">Out</span><% } else { %><%= p.stock_qty %><% } %>
        </td>
        <td class="muted"><%= p.size || '' %></td>
        <td><span class="adm-pill <%= p.is_active ? 'on' : 'off' %>"><%= p.is_active ? 'Active' : 'Hidden' %></span></td>
        <td class="num"><%= p.click_count %></td>
        <td class="actions">
          <a class="adm-btn-ghost small" href="/admin/products/<%= p.id %>/edit">Edit</a>
          <form class="adm-inline-form" method="post" action="/admin/products/<%= p.id %>/delete" data-confirm="Delete <%= p.name %>? Its images and SEO settings go with it.">
            <input type="hidden" name="_csrf" value="<%= csrf %>">
            <button type="submit" class="adm-btn-danger">Delete</button>
          </form>
        </td>
      </tr>
      <% }); %>
      <% if (!products.length) { %>
      <tr><td colspan="10" class="muted">No products yet</td></tr>
      <% } %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
  <nav class="adm-pager" aria-label="Product pages">
    <% if (currentPage > 1) { %>
    <a href="<%= pageLink(currentPage - 1) %>">Prev</a>
    <% } else { %>
    <span class="disabled">Prev</span>
    <% } %>
    <% for (var pn = 1; pn <= totalPages; pn++) { %>
    <a href="<%= pageLink(pn) %>" class="<%= pn === currentPage ? 'on' : '' %>"><%= pn %></a>
    <% } %>
    <% if (currentPage < totalPages) { %>
    <a href="<%= pageLink(currentPage + 1) %>">Next</a>
    <% } else { %>
    <span class="disabled">Next</span>
    <% } %>
  </nav>
  <% } %>
</section>
<%- include('../partials/bottom') %>
