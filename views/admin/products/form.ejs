<%- include('../partials/top') %>
<% const p = product || {}; const s = seo || {}; const isNew = !p.id; %>
<header class="adm-head">
  <h1><%= isNew ? 'Add product' : 'Edit product' %></h1>
  <div class="adm-head-actions">
    <% if (!isNew) { %>
    <a class="adm-btn-ghost" href="/products/<%= p.slug %>" target="_blank" rel="noopener">View page</a>
    <% } %>
    <a class="adm-btn-ghost" href="/admin/products">Back to list</a>
  </div>
</header>

<style>
  .prod-img-tiles { display: flex; flex-wrap: wrap; gap: 10px; margin: 6px 0 4px; }
  .prod-img-tiles .tile {
    position: relative; width: 132px; border: 2px solid var(--line); border-radius: 10px;
    overflow: hidden; background: var(--white);
  }
  .prod-img-tiles .tile img { width: 100%; aspect-ratio: 1; object-fit: cover; display: block; }
  .prod-img-tiles .tile.off img { opacity: .35; }
  .prod-img-tiles .tile .flag {
    position: absolute; top: 6px; left: 6px; background: var(--accent); color: #fff;
    font-size: 10px; font-weight: 700; letter-spacing: .02em; padding: 2px 8px; border-radius: 999px;
  }
  .prod-img-tiles .tile .opts { padding: 6px 8px; display: grid; gap: 4px; }
  .prod-img-tiles .tile .opts label {
    display: flex; align-items: center; gap: 5px; margin: 0;
    font-weight: 400; font-size: 11px; cursor: pointer;
  }
  .prod-img-tiles .tile .opts input { width: auto; margin: 0; }
</style>

<form class="adm-form" method="post" action="<%= isNew ? '/admin/products' : '/admin/products/' + p.id %>" enctype="multipart/form-data">
  <input type="hidden" name="_csrf" value="<%= csrf %>">
  <% if (error) { %><div class="adm-error"><%= error %></div><% } %>

  <section class="adm-panel">
    <h2>Basics</h2>
    <div class="adm-grid2">
      <label>Name
        <input type="text" name="name" id="prod-name" required maxlength="150" value="<%= p.name || '' %>">
      </label>
      <label>Slug <small>lowercase letters, numbers and hyphens</small>
        <input type="text" name="slug" id="prod-slug" required maxlength="120" pattern="[a-z0-9-]+" value="<%= p.slug || '' %>">
      </label>
    </div>
    <div class="adm-grid3">
      <label>Vehicle
        <select name="vehicle">
          <option value="car" <%= p.vehicle === 'car' ? 'selected' : '' %>>Car</option>
          <option value="bike" <%= p.vehicle === 'bike' ? 'selected' : '' %>>Bike</option>
          <option value="both" <%= !p.vehicle || p.vehicle === 'both' ? 'selected' : '' %>>Both</option>
        </select>
      </label>
      <label>Category <small>shown in listing filters</small>
        <input type="text" name="category" maxlength="100" value="<%= p.category || '' %>">
      </label>
      <label>Price (LKR)
        <input type="number" name="price_lkr" required step="0.01" min="0" value="<%= p.price_lkr != null ? p.price_lkr : '' %>">
      </label>
    </div>
    <div class="adm-grid3">
      <label>Size <small>e.g. 500ml</small>
        <input type="text" name="size" maxlength="50" value="<%= p.size || '' %>">
      </label>
      <label>SKU
        <input type="text" name="sku" maxlength="50" value="<%= p.sku || '' %>">
      </label>
      <label class="check">
        <input type="checkbox" name="is_active" value="1" <%= isNew || p.is_active ? 'checked' : '' %>>
        Show on the site
      </label>
    </div>
    <div class="adm-grid3">
      <label>Stock
        <input type="number" name="stock_qty" id="prod-stock" min="0" step="1" value="<%= p.stock_qty != null ? p.stock_qty : '' %>" <%= p.stock_qty == null ? 'disabled' : '' %>>
      </label>
      <label class="check">
        <input type="checkbox" name="stock_unlimited" value="1" id="prod-stock-unlimited" <%= p.stock_qty == null ? 'checked' : '' %>>
        Unlimited stock
      </label>
    </div>
    <p class="adm-panel-note">Customers cannot order more than the stock on hand. Unlimited means no tracking.</p>
  </section>

  <section class="adm-panel">
    <h2>Copy</h2>
    <label>Listing blurb <small>short text on listing cards</small>
      <input type="text" name="listing_blurb" maxlength="255" value="<%= p.listing_blurb || '' %>">
    </label>
    <label>Short description
      <textarea name="short_description"><%= p.short_description || '' %></textarea>
    </label>
    <div class="adm-field">Description
      <div class="adm-editor">
        <div class="adm-editor-tabs">
          <button type="button" class="adm-editor-tab active" data-editor-tab="visual">Visual</button>
          <button type="button" class="adm-editor-tab" data-editor-tab="html">HTML</button>
        </div>
        <div class="adm-editor-bar">
          <button type="button" class="wide" data-cmd="formatBlock" data-value="H2">H2</button>
          <button type="button" class="wide" data-cmd="formatBlock" data-value="H3">H3</button>
          <button type="button" class="wide" data-cmd="formatBlock" data-value="P">P</button>
          <button type="button" data-cmd="bold" title="Bold">B</button>
          <button type="button" data-cmd="italic" title="Italic"><i>I</i></button>
          <button type="button" data-cmd="insertUnorderedList" title="Bullet list">&bull;</button>
          <button type="button" data-cmd="insertOrderedList" title="Numbered list">1.</button>
          <button type="button" class="wide" data-cmd="createLink" title="Insert link">Link</button>
          <button type="button" class="wide" data-cmd="removeFormat" title="Clear formatting">Clear</button>
        </div>
        <div class="adm-editor-area" contenteditable="true"></div>
        <textarea class="adm-editor-src" name="description_html"><%= p.description_html || '' %></textarea>
      </div>
    </div>
    <label>Features <small>one bullet per line</small>
      <textarea name="features"><%= featuresText %></textarea>
    </label>
    <label>Specs <small>one per line in the form Label | Value</small>
      <textarea name="specs"><%= specsText %></textarea>
    </label>
    <label>How to use <small>one step per line</small>
      <textarea name="how_to_use"><%= howToText %></textarea>
    </label>
  </section>

  <section class="adm-panel">
    <h2>Images</h2>
    <% if (images.length) { %>
    <div class="prod-img-tiles" id="prod-images">
      <% images.forEach(function (img) { %>
      <div class="tile">
        <img src="/media/<%= img.file_path %>" alt="<%= img.alt_text || img.file_path %>" title="<%= img.file_path %>">
        <% if (img.role === 'featured') { %><span class="flag">Featured</span><% } %>
        <div class="opts">
          <label><input type="radio" name="featured_media" value="<%= img.media_id %>" <%= featuredId === img.media_id ? 'checked' : '' %>> Featured</label>
          <label><input type="checkbox" name="keep_media[]" value="<%= img.media_id %>" <%= keptIds.indexOf(img.media_id) !== -1 ? 'checked' : '' %>> Keep on product</label>
        </div>
      </div>
      <% }); %>
    </div>
    <p class="adm-panel-note">Untick Keep to take an image off this product when you save. The file stays in the media library.</p>
    <% } %>
    <div class="adm-upload-row">
      <label><%= images.length ? 'Upload more images' : 'Upload images' %>
        <input type="file" name="new_images" accept="image/*" multiple>
      </label>
    </div>
    <% if (images.length) { %>
    <p class="adm-panel-note">Uploaded images join the gallery automatically, tick the radio to make one featured.</p>
    <% } else { %>
    <p class="adm-panel-note">No images yet. Upload some and they attach to this product on save, the first one becomes the featured image.</p>
    <% } %>
  </section>

  <section class="adm-panel">
    <h2>You might also like</h2>
    <% if (otherProducts.length) { %>
    <p class="adm-panel-note" id="prod-related-note">Pick up to 3. Leave empty to pick automatically by category.</p>
    <div class="adm-grid2" id="prod-related">
      <% otherProducts.forEach(function (op) { %>
      <label class="check">
        <input type="checkbox" name="related_ids[]" value="<%= op.id %>" <%= relatedIds.indexOf(op.id) !== -1 ? 'checked' : '' %>>
        <%= op.name %>
      </label>
      <% }); %>
    </div>
    <% } else { %>
    <p class="adm-panel-note">No other active products yet. Once there are, you can hand-pick up to 3 here.</p>
    <% } %>
  </section>

  <section class="adm-panel">
    <h2>SEO</h2>
    <div class="adm-grid2">
      <label>SEO title
        <input type="text" name="seo_title" maxlength="70" value="<%= s.seo_title || '' %>">
      </label>
      <label>Focus keyphrase
        <input type="text" name="focus_keyphrase" maxlength="120" value="<%= s.focus_keyphrase || '' %>">
      </label>
      <label class="adm-span2">Meta description <small id="meta-desc-count"></small>
        <textarea name="meta_description" id="meta-desc" maxlength="200"><%= s.meta_description || '' %></textarea>
      </label>
      <label class="check">
        <input type="checkbox" name="cornerstone" value="1" <%= s.cornerstone ? 'checked' : '' %>>
        Cornerstone content
      </label>
      <label>Breadcrumbs title
        <input type="text" name="breadcrumbs_title" maxlength="120" value="<%= s.breadcrumbs_title || '' %>">
      </label>
      <label>Canonical URL <small>Leave blank to auto-generate</small>
        <input type="text" name="canonical_url" id="canonical-url" maxlength="255" placeholder="<%= baseUrl %>/products/<%= p.slug || '' %>" value="<%= s.canonical_url || '' %>">
      </label>
      <label>Page type
        <select name="page_type">
          <% pageTypes.forEach(function (t) { %>
          <option value="<%= t %>" <%= (s.page_type || 'Item Page') === t ? 'selected' : '' %>><%= t %></option>
          <% }); %>
        </select>
      </label>
      <label>Article type
        <select name="article_type">
          <% articleTypes.forEach(function (t) { %>
          <option value="<%= t %>" <%= (s.article_type || 'None') === t ? 'selected' : '' %>><%= t %></option>
          <% }); %>
        </select>
      </label>
      <label class="adm-span2">Social title
        <input type="text" name="social_title" maxlength="120" value="<%= s.social_title || '' %>">
      </label>
      <label class="adm-span2">Social description
        <textarea name="social_description" maxlength="300"><%= s.social_description || '' %></textarea>
      </label>
      <label class="adm-span2">X title
        <input type="text" name="x_title" maxlength="120" value="<%= s.x_title || '' %>">
      </label>
      <label class="adm-span2">X description
        <textarea name="x_description" maxlength="300"><%= s.x_description || '' %></textarea>
      </label>
      <label class="adm-span2">Excerpt
        <textarea name="excerpt"><%= s.excerpt || '' %></textarea>
      </label>
    </div>
  </section>

  <div class="adm-form-actions">
    <button type="submit" class="adm-btn">Save product</button>
    <a class="adm-btn-ghost" href="/admin/products">Cancel</a>
  </div>
</form>

<script>
(function () {
  var nameInput = document.getElementById('prod-name');
  var slugInput = document.getElementById('prod-slug');
  var canonical = document.getElementById('canonical-url');
  var isNew = <%= isNew ? 'true' : 'false' %>;
  var slugTouched = !isNew || !!slugInput.value;

  function slugify(text) {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  }
  function updateCanonical() {
    canonical.placeholder = '<%= baseUrl %>/products/' + slugInput.value;
  }
  nameInput.addEventListener('input', function () {
    if (!slugTouched) {
      slugInput.value = slugify(nameInput.value);
      updateCanonical();
    }
  });
  slugInput.addEventListener('input', function () {
    slugTouched = true;
    updateCanonical();
  });

  var stockInput = document.getElementById('prod-stock');
  var stockUnlimited = document.getElementById('prod-stock-unlimited');
  function syncStock() { stockInput.disabled = stockUnlimited.checked; }
  stockUnlimited.addEventListener('change', syncStock);
  syncStock();

  var ta = document.getElementById('meta-desc');
  var out = document.getElementById('meta-desc-count');
  function count() { out.textContent = ta.value.length + ' / 200'; }
  ta.addEventListener('input', count);
  count();

  var tiles = document.getElementById('prod-images');
  if (tiles) {
    var refreshTiles = function () {
      tiles.querySelectorAll('.tile').forEach(function (tile) {
        var keep = tile.querySelector('input[type="checkbox"]');
        tile.classList.toggle('off', !keep.checked);
      });
    };
    tiles.addEventListener('change', refreshTiles);
    refreshTiles();
  }

  var related = document.getElementById('prod-related');
  if (related) {
    var relBoxes = related.querySelectorAll('input[type="checkbox"]');
    var capRelated = function () {
      var ticked = related.querySelectorAll('input:checked').length;
      relBoxes.forEach(function (box) {
        if (!box.checked) box.disabled = ticked >= 3;
      });
    };
    related.addEventListener('change', capRelated);
    capRelated();
  }
})();
</script>
<%- include('../partials/bottom') %>
