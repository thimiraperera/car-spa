<%- include('../partials/top') %>
<header class="adm-head">
  <h1>Settings</h1>
</header>

<style>
  .adm-upload-row label { display: inline; margin-bottom: 0; font-weight: 400; font-size: 13px; }
</style>

<form class="adm-form" method="post" action="/admin/settings" enctype="multipart/form-data">
  <input type="hidden" name="_csrf" value="<%= csrf %>">

  <section class="adm-panel">
    <h2>Display settings</h2>
    <div class="adm-grid3">
      <label>Carousel product count
        <small>How many recent products the homepage carousel shows</small>
        <input type="number" name="carousel_product_count" min="1" max="24" step="1" required value="<%= values.carousel_product_count %>">
      </label>
      <label>Testimonials count
        <small>How many recent testimonials the homepage shows</small>
        <input type="number" name="testimonials_count" min="1" max="30" step="1" required value="<%= values.testimonials_count %>">
      </label>
      <label>Hero picks count
        <small>Products per vehicle in the hero Popular now strip</small>
        <input type="number" name="hero_picks_count" min="1" max="6" step="1" required value="<%= values.hero_picks_count %>">
      </label>
    </div>
  </section>

  <section class="adm-panel">
    <h2>Images</h2>
    <div class="adm-grid3">
      <label>Max image dimension
        <small>Uploads are converted to webp and resized so the longest side stays under this</small>
        <input type="number" name="image_max_dimension" min="256" max="4096" step="64" required value="<%= values.image_max_dimension %>">
      </label>
    </div>
  </section>

  <section class="adm-panel">
    <h2>Branding</h2>
    <% const logoFields = [
      { key: 'site_logo_media_id', label: 'Site logo', help: '' },
      { key: 'mail_header_logo_media_id', label: 'Mail template header logo', help: 'Shown at the top of outgoing emails, PNG recommended for email clients' },
      { key: 'dark_mode_logo_media_id', label: 'Dark mode logo', help: 'Used on the transparent homepage header over the dark hero image, upload a light or white colored version' },
      { key: 'light_mode_logo_media_id', label: 'Light mode logo', help: 'Used on the solid white header on every other page, upload a dark colored version' }
    ]; %>
    <% logoFields.forEach(function (lf) { %>
    <div class="adm-field">
      <%= lf.label %><% if (lf.help) { %> <small><%= lf.help %></small><% } %>
      <div class="adm-upload-row">
        <% if (logos[lf.key]) { %>
        <img src="/media/<%= logos[lf.key].file_path %>" alt="Current <%= lf.label.toLowerCase() %>">
        <% } %>
        <input type="file" name="<%= lf.key %>_file" accept="image/*">
        <% if (logos[lf.key]) { %>
        <label><input type="checkbox" name="<%= lf.key %>_clear" value="1"> Remove</label>
        <% } %>
      </div>
    </div>
    <% }); %>
  </section>

  <div class="adm-form-actions">
    <button type="submit" class="adm-btn">Save settings</button>
  </div>
</form>
<%- include('../partials/bottom') %>
