<%- include('partials/top') %>
<% const me = admin || {}; %>
<header class="adm-head">
  <h1>My profile</h1>
</header>

<style>
  .adm-upload-row .avatar-prev { border-radius: 50%; object-fit: cover; padding: 0; }
  .adm-upload-row .adm-avatar-fallback { width: 64px; height: 64px; font-size: 24px; }
</style>

<form class="adm-form" method="post" action="/admin/profile" enctype="multipart/form-data">
  <input type="hidden" name="_csrf" value="<%= csrf %>">
  <% if (error) { %><div class="adm-error"><%= error %></div><% } %>

  <section class="adm-panel">
    <h2>Details</h2>
    <div class="adm-grid2">
      <label>Username <small>cannot be changed here</small>
        <input type="text" value="<%= me.username || '' %>" disabled>
      </label>
      <label>Nickname <small>shown around the admin instead of your username</small>
        <input type="text" name="nickname" maxlength="60" value="<%= me.nickname || '' %>">
      </label>
      <label>First name
        <input type="text" name="first_name" maxlength="60" value="<%= me.first_name || '' %>">
      </label>
      <label>Last name
        <input type="text" name="last_name" maxlength="60" value="<%= me.last_name || '' %>">
      </label>
      <label class="adm-span2">Email
        <input type="email" name="email" maxlength="190" value="<%= me.email || '' %>">
      </label>
    </div>

    <div class="adm-field">Avatar
      <div class="adm-upload-row">
        <% if (me.avatar_file_path) { %>
        <img class="avatar-prev" src="/media/<%= me.avatar_file_path %>" alt="Current avatar">
        <% } else { %>
        <span class="adm-avatar-fallback"><%= String(me.nickname || me.first_name || me.username || '?').charAt(0).toUpperCase() %></span>
        <% } %>
        <label>Upload a photo <input type="file" name="avatar_file" accept="image/*"></label>
        <% if (me.avatar_file_path) { %>
        <label class="check">
          <input type="checkbox" name="avatar_clear" value="1"> Remove current photo
        </label>
        <% } %>
      </div>
    </div>

    <div class="adm-form-actions">
      <button type="submit" class="adm-btn">Save profile</button>
    </div>
  </section>
</form>

<section class="adm-panel">
  <h2>Change password</h2>
  <% if (passwordError) { %><div class="adm-error"><%= passwordError %></div><% } %>
  <form class="adm-form" method="post" action="/admin/profile/password">
    <input type="hidden" name="_csrf" value="<%= csrf %>">
    <div class="adm-grid3">
      <label>Current password
        <input type="password" name="current_password" required autocomplete="current-password">
      </label>
      <label>New password
        <input type="password" name="new_password" required minlength="8" autocomplete="new-password">
      </label>
      <label>Confirm new password
        <input type="password" name="confirm_password" required minlength="8" autocomplete="new-password">
      </label>
    </div>
    <div class="adm-form-actions">
      <button type="submit" class="adm-btn">Change password</button>
    </div>
  </form>
</section>
<%- include('partials/bottom') %>
