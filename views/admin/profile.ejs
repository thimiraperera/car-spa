<%- include('partials/top') %>
<% const me = admin || {}; %>
<header class="adm-head">
  <h1>My profile</h1>
</header>

<style>
  .adm-imgpick .pick.none-pick { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; }
  .adm-imgpick .pick.none-pick .none-ph { font-size: 11px; color: var(--ink-soft); }
</style>

<form class="adm-form" method="post" action="/admin/profile">
  <input type="hidden" name="_csrf" value="<%= csrf %>">
  <% if (error) { %><div class="adm-error"><%= error %></div><% } %>

  <section class="adm-panel">
    <h2>Details</h2>
    <div class="adm-grid2">
      <label>Username <small>cannot be changed here</small>
        <input type="text" value="<%= me.username || '' %>" disabled>
      </label>
      <label>Email
        <input type="email" name="email" maxlength="190" value="<%= me.email || '' %>">
      </label>
      <label>First name
        <input type="text" name="first_name" maxlength="60" value="<%= me.first_name || '' %>">
      </label>
      <label>Last name
        <input type="text" name="last_name" maxlength="60" value="<%= me.last_name || '' %>">
      </label>
    </div>
  </section>

  <section class="adm-panel">
    <h2>Avatar</h2>
    <% if (media.length) { %>
    <div class="adm-imgpick" id="imgpick">
      <div class="pick none-pick<%= !me.avatar_media_id ? ' sel' : '' %>">
        <span class="none-ph">None</span>
        <span class="tag"><input type="radio" name="avatar_media" value="" <%= !me.avatar_media_id ? 'checked' : '' %>></span>
      </div>
      <% media.forEach(function (m) { %>
      <% const isSel = me.avatar_media_id === m.id; %>
      <div class="pick<%= isSel ? ' sel' : '' %>">
        <img src="/media/<%= m.file_path %>" alt="<%= m.alt_text || m.file_path %>" title="<%= m.file_path %>">
        <span class="tag"><input type="radio" name="avatar_media" value="<%= m.id %>" <%= isSel ? 'checked' : '' %>></span>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <p class="adm-panel-note">The media library is empty. Upload a photo in <a href="/admin/media">Media</a>.</p>
    <% } %>
  </section>

  <div class="adm-form-actions">
    <button type="submit" class="adm-btn">Save profile</button>
  </div>
</form>

<section class="adm-panel">
  <h2>Change password</h2>
  <% if (passwordError) { %><div class="adm-error"><%= passwordError %></div><% } %>
  <form class="adm-form" method="post" action="/admin/profile/password">
    <input type="hidden" name="_csrf" value="<%= csrf %>">
    <div class="adm-grid3">
      <label>Current password
        <input type="password" name="current_password" required autocomplete="current-password">
      </label>
      <label>New password
        <input type="password" name="new_password" required minlength="8" autocomplete="new-password">
      </label>
      <label>Confirm new password
        <input type="password" name="confirm_password" required minlength="8" autocomplete="new-password">
      </label>
    </div>
    <div class="adm-form-actions">
      <button type="submit" class="adm-btn">Change password</button>
    </div>
  </form>
</section>

<script>
(function () {
  var grid = document.getElementById('imgpick');
  if (grid) {
    var refresh = function () {
      grid.querySelectorAll('.pick').forEach(function (pick) {
        pick.classList.toggle('sel', !!pick.querySelector('input:checked'));
      });
    };
    grid.addEventListener('change', refresh);
    refresh();
  }
})();
</script>
<%- include('partials/bottom') %>
