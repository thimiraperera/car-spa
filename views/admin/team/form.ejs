<%- include('../partials/top') %>
<% const a = item || {}; const isNew = !a.id; %>
<header class="adm-head">
  <h1><%= isNew ? 'Add admin' : 'Edit admin' %></h1>
  <div class="adm-head-actions">
    <a class="adm-btn-ghost" href="/admin/team">Back to list</a>
  </div>
</header>

<form class="adm-form" method="post" enctype="multipart/form-data" action="<%= isNew ? '/admin/team' : '/admin/team/' + a.id %>">
  <input type="hidden" name="_csrf" value="<%= csrf %>">
  <% if (error) { %><div class="adm-error"><%= error %></div><% } %>

  <section class="adm-panel">
    <h2>Account</h2>
    <div class="adm-grid2">
      <label>Username
        <input type="text" name="username" required maxlength="50" value="<%= a.username || '' %>">
      </label>
      <label>Email
        <input type="email" name="email" <%= isNew ? 'required' : '' %> maxlength="190" value="<%= a.email || '' %>">
      </label>
      <label>First name
        <input type="text" name="first_name" maxlength="60" value="<%= a.first_name || '' %>">
      </label>
      <label>Last name
        <input type="text" name="last_name" maxlength="60" value="<%= a.last_name || '' %>">
      </label>
      <% if (isNew) { %>
      <label>Temporary password <small>at least 8 characters, shown once here</small>
        <input type="text" name="password" required minlength="8" value="<%= a.password || '' %>">
      </label>
      <% } %>
    </div>
  </section>

  <section class="adm-panel">
    <h2>Avatar</h2>
    <div class="adm-upload-row">
      <% if (a.avatar_file_path) { %>
      <img src="/media/<%= a.avatar_file_path %>" alt="" style="border-radius: 50%;">
      <% } %>
      <label>Upload a photo <input type="file" name="avatar_file" accept="image/*"></label>
      <% if (a.avatar_file_path) { %>
      <label class="check"><input type="checkbox" name="avatar_clear" value="1"> Remove</label>
      <% } %>
    </div>
    <p class="adm-panel-note">Replacing or removing the photo also deletes the old file when nothing else uses it.</p>
  </section>

  <div class="adm-form-actions">
    <button type="submit" class="adm-btn"><%= isNew ? 'Create admin' : 'Save changes' %></button>
    <a class="adm-btn-ghost" href="/admin/team">Cancel</a>
  </div>
</form>

<% if (!isNew) { %>
<section class="adm-panel">
  <h2>Set password</h2>
  <p class="adm-panel-note">Directly sets <%= a.username %>'s password. They are not notified.</p>
  <form class="adm-form" method="post" action="/admin/team/<%= a.id %>/password">
    <input type="hidden" name="_csrf" value="<%= csrf %>">
    <div class="adm-grid2">
      <label>New password
        <input type="password" name="new_password" required minlength="8" autocomplete="new-password">
      </label>
      <label>Confirm password
        <input type="password" name="confirm_password" required minlength="8" autocomplete="new-password">
      </label>
    </div>
    <div class="adm-form-actions">
      <button type="submit" class="adm-btn">Set password</button>
    </div>
  </form>
</section>
<% } %>
<%- include('../partials/bottom') %>
