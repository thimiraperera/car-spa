<%- include('../partials/top') %>
<% const a = item || {}; const isNew = !a.id; %>
<header class="adm-head">
  <h1><%= isNew ? 'Add admin' : 'Edit admin' %></h1>
  <div class="adm-head-actions">
    <a class="adm-btn-ghost" href="/admin/team">Back to list</a>
  </div>
</header>

<style>
  .adm-imgpick .pick.none-pick { aspect-ratio: 1; display: flex; align-items: center; justify-content: center; }
  .adm-imgpick .pick.none-pick .none-ph { font-size: 11px; color: var(--ink-soft); }
</style>

<form class="adm-form" method="post" action="<%= isNew ? '/admin/team' : '/admin/team/' + a.id %>">
  <input type="hidden" name="_csrf" value="<%= csrf %>">
  <% if (error) { %><div class="adm-error"><%= error %></div><% } %>

  <section class="adm-panel">
    <h2>Account</h2>
    <div class="adm-grid2">
      <label>Username
        <input type="text" name="username" required maxlength="50" value="<%= a.username || '' %>">
      </label>
      <label>Email
        <input type="email" name="email" <%= isNew ? 'required' : '' %> maxlength="190" value="<%= a.email || '' %>">
      </label>
      <label>First name
        <input type="text" name="first_name" maxlength="60" value="<%= a.first_name || '' %>">
      </label>
      <label>Last name
        <input type="text" name="last_name" maxlength="60" value="<%= a.last_name || '' %>">
      </label>
      <% if (isNew) { %>
      <label>Temporary password <small>at least 8 characters, shown once here</small>
        <input type="text" name="password" required minlength="8" value="<%= a.password || '' %>">
      </label>
      <% } %>
    </div>
  </section>

  <section class="adm-panel">
    <h2>Avatar</h2>
    <% if (media.length) { %>
    <div class="adm-imgpick" id="imgpick">
      <div class="pick none-pick<%= !a.avatar_media_id ? ' sel' : '' %>">
        <span class="none-ph">None</span>
        <span class="tag"><input type="radio" name="avatar_media" value="" <%= !a.avatar_media_id ? 'checked' : '' %>></span>
      </div>
      <% media.forEach(function (m) { %>
      <% const isSel = a.avatar_media_id === m.id; %>
      <div class="pick<%= isSel ? ' sel' : '' %>">
        <img src="/media/<%= m.file_path %>" alt="<%= m.alt_text || m.file_path %>" title="<%= m.file_path %>">
        <span class="tag"><input type="radio" name="avatar_media" value="<%= m.id %>" <%= isSel ? 'checked' : '' %>></span>
      </div>
      <% }); %>
    </div>
    <% } else { %>
    <p class="adm-panel-note">The media library is empty. Upload a photo in <a href="/admin/media">Media</a>.</p>
    <% } %>
  </section>

  <div class="adm-form-actions">
    <button type="submit" class="adm-btn"><%= isNew ? 'Create admin' : 'Save changes' %></button>
    <a class="adm-btn-ghost" href="/admin/team">Cancel</a>
  </div>
</form>

<% if (!isNew) { %>
<section class="adm-panel">
  <h2>Set password</h2>
  <p class="adm-panel-note">Directly sets <%= a.username %>'s password. They are not notified.</p>
  <form class="adm-form" method="post" action="/admin/team/<%= a.id %>/password">
    <input type="hidden" name="_csrf" value="<%= csrf %>">
    <div class="adm-grid2">
      <label>New password
        <input type="password" name="new_password" required minlength="8" autocomplete="new-password">
      </label>
      <label>Confirm password
        <input type="password" name="confirm_password" required minlength="8" autocomplete="new-password">
      </label>
    </div>
    <div class="adm-form-actions">
      <button type="submit" class="adm-btn">Set password</button>
    </div>
  </form>
</section>
<% } %>

<script>
(function () {
  var grid = document.getElementById('imgpick');
  if (grid) {
    var refresh = function () {
      grid.querySelectorAll('.pick').forEach(function (pick) {
        pick.classList.toggle('sel', !!pick.querySelector('input:checked'));
      });
    };
    grid.addEventListener('change', refresh);
    refresh();
  }
})();
</script>
<%- include('../partials/bottom') %>
