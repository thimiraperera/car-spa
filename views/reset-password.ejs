<!DOCTYPE html><html lang="en"><head><%- include('partials/head') %></head><body>
<%- include('partials/header') %>

<div class="page-hero">
  <div class="page-hero-panel">
    <h1>RESET <span style="color:var(--accent)">PASSWORD</span></h1>
    <p>Choose a new password for your admin account.</p>
  </div>
</div>

<style>
  .rp-wrap { max-width: 460px; margin: 0 auto; }
  .rp-wrap .form-error { margin-top: 4px; margin-bottom: 16px; font-size: 14px; color: var(--accent-dark); font-weight: 700; }
</style>

<section class="page-shell">
  <div class="container">
    <div class="rp-wrap">
      <div class="co-panel reveal">
        <h3>Set a new password</h3>
        <% if (!valid) { %>
        <p class="form-error">This link is invalid or has expired. Request a new one from the <a href="/forgot-password">forgot password</a> page.</p>
        <% } else { %>
        <% if (error) { %><p class="form-error"><%= error %></p><% } %>
        <form method="post" action="/reset-password/<%= token %>">
          <div class="form-field">
            <label for="rp-password">New password</label>
            <input id="rp-password" name="password" type="password" required minlength="8" autocomplete="new-password">
          </div>
          <div class="form-field">
            <label for="rp-confirm">Confirm new password</label>
            <input id="rp-confirm" name="confirm_password" type="password" required minlength="8" autocomplete="new-password">
          </div>
          <button class="btn btn-accent" type="submit">Set new password <span class="arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h13M13 6l6 6-6 6"/></svg></span></button>
        </form>
        <% } %>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
</body>
</html>
